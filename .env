# ============================================
# Nebula 项目环境变量配置示例
# ============================================
# 使用方法：
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 修改 .env 文件中的值为你自己的配置
# 3. .env 文件已被 .gitignore 忽略，不会提交到代码库
# ============================================

# --------------------------------------------
# GitHub OAuth 配置（必填）
# 在 https://github.com/settings/developers 创建 OAuth App
# --------------------------------------------
GITHUB_CLIENT_ID=Ov23lisH1zy6aIiT5f9r
GITHUB_CLIENT_SECRET=53fb8a6dd24bad3a37c40c8c37c76b9bd487521f

# GitHub OAuth 回调地址（根据环境修改）
# 本地开发环境
GITHUB_REDIRECT_URI=http://localhost:8080/api/oauth/github/callback
# 前端回调地址
FRONTEND_CALLBACK_URL=http://localhost:3000/auth/github/callback

# --------------------------------------------
# 数据库配置（根据你的环境修改）
# --------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nebula
DB_USER=admin
DB_PASSWORD=admin

# 数据库连接池配置（可选）
DB_MAX_CONNECTIONS=20
DB_TIMEOUT=30000

# --------------------------------------------
# Redis 配置（根据你的环境修改）
# --------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=123123
REDIS_DATABASE=0

# Redis 连接池配置（可选）
REDIS_MAX_ACTIVE=8
REDIS_MAX_IDLE=8
REDIS_TIMEOUT=5000

# --------------------------------------------
# JWT 配置（生产环境务必使用复杂密钥）
# --------------------------------------------
JWT_SECRET=nebula-secret-key-2024-spring-boot-jwt-token-refresh-enabled
JWT_ACCESS_TOKEN_EXPIRE=1800000
JWT_REFRESH_TOKEN_EXPIRE=604800000

# --------------------------------------------
# MinIO 配置（可选，用于文件上传）
# --------------------------------------------
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=user-uploads

# --------------------------------------------
# 邮件服务配置（可选，用于邮件验证）
# --------------------------------------------
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-app-password

# --------------------------------------------
# 日志级别配置（可选）
# --------------------------------------------
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_NEBULA=DEBUG
LOG_LEVEL_SPRING=WARN

# --------------------------------------------
# 服务器配置（可选）
# --------------------------------------------
SERVER_PORT=8080
SERVER_CONTEXT_PATH=/

# ============================================
# 重要提示：
# 1. 永远不要提交真实的 .env 文件到代码库
# 2. 生产环境的敏感配置应该使用 CI/CD 的 Secrets 功能
# 3. 定期更换 GitHub OAuth 等敏感密钥
# ============================================